# LangSmith adalah platform untuk melihat, memonitor, dan mengevaluasi performa chatbot yang dibangun dengan LangChain.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="your_api_key_here"
LANGSMITH_PROJECT="your_name_project"
TOKENIZERS_PARALLELISM=false

# Groq API untuk model bahasa
GROQ_API_KEY="your_api_key_here"

#PINECONE untuk vector store
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment

#CLOUDINARY untuk penyimpanan file
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Path untuk FAISS dan dokumen
DOCUMENTS_PATH=data-rag/documents

# MySQL Config
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=multimodal_assistant_db
MYSQL_PORT=3306

